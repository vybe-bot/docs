{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "VybeBot",
  "description": "Learn how to build, deploy, and manage Discord, Telegram, and custom bots with VybeBot.",
  "colors": {
    "primary": "#FF8A2A",
    "light": "#FF8A2A",
    "dark": "#F3743F"
  },
  "favicon": {
    "light": "/images/vybebot.png",
    "dark": "/images/vybebot.png"
  },
  "logo": {
    "light": "/images/vybebot-wordmark.png",
    "dark": "/images/vybebot-wordmark.png",
    "href": "/introduction"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "introduction",
          "getting-started/quickstart",
          "getting-started/core-concepts",
          "getting-started/discord-bot",
          "getting-started/telegram-bot"
        ]
      },
      {
        "group": "Build with Vyber",
        "pages": [
          "build/vyber-workspace",
          "build/prompting",
          "build/files-and-history",
          "build/branches-and-sessions",
          "build/skills"
        ]
      },
      {
        "group": "Connect and configure",
        "pages": [
          "configure/secrets-and-runtime",
          "configure/app-integrations",
          "configure/mcp-connectors",
          "configure/github"
        ]
      },
      {
        "group": "Deploy and operate",
        "pages": [
          "deploy/deployments",
          "deploy/logs",
          "deploy/domains",
          "deploy/persistent-storage"
        ]
      },
      {
        "group": "Workspaces and teams",
        "pages": [
          "workspace/workspaces",
          "workspace/team-and-permissions",
          "workspace/knowledge",
          "workspace/billing-and-credits"
        ]
      },
      {
        "group": "Share and extend",
        "pages": [
          "share/explore-and-remix",
          "advanced/chatgpt-mcp"
        ]
      },
      {
        "group": "Help and reference",
        "pages": [
          "help/troubleshooting",
          "help/glossary"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@vybebot.com"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/6BdB22Rc97"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open VybeBot",
      "href": "https://vybebot.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/vybe_bot",
      "linkedin": "https://linkedin.com/company/vybebot",
      "discord": "https://discord.gg/6BdB22Rc97"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "icons": {
    "library": "lucide"
  }
}
